{
  "name": "@syncraft/vue",
  "version": "0.1.0",
  "description": "Vue composables for Syncraft — local-first state synchronization.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@syncraft/core": "^0.1.0"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^26.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "vue": "^3.5.0"
  },
  "sideEffects": false,
  "keywords": [
    "syncraft",
    "vue",
    "composable",
    "local-first",
    "offline",
    "sync"
  ]
}
