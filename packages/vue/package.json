{
  "name": "@syncraft-labs/vue",
  "version": "0.2.1",
  "description": "Vue 3 composables for Syncraft Labs — local-first state synchronization.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@syncraft-labs/core": "^0.2.0"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^26.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "vue": "^3.5.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denislistiadi/syncraft-labs.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/denislistiadi/syncraft-labs/issues"
  },
  "homepage": "https://syncraft-labs.netlify.app",
  "author": "Denis Listiadi",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "syncraft-labs",
    "vue",
    "composable",
    "local-first",
    "offline",
    "sync",
    "shallowRef",
    "composition-api"
  ]
}
