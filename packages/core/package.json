{
  "name": "@syncraft/core",
  "version": "0.1.0",
  "description": "Local-first state synchronization engine — core library.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "immer": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "fake-indexeddb": "^6.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "sideEffects": false,
  "keywords": [
    "sync",
    "local-first",
    "offline",
    "indexeddb",
    "optimistic-ui",
    "state"
  ]
}
