{
  "name": "@syncraft-labs/core",
  "version": "0.2.1",
  "description": "Local-first state synchronization engine — core library.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "immer": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "fake-indexeddb": "^6.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denislistiadi/syncraft-labs.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/denislistiadi/syncraft-labs/issues"
  },
  "homepage": "https://syncraft-labs.netlify.app",
  "author": "Denis Listiadi",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sync",
    "local-first",
    "offline",
    "indexeddb",
    "optimistic-ui",
    "state",
    "immer",
    "persistence"
  ]
}
